OPENAI_API_KEY=sk-...
CHAT_API_KEY=change-me

# Defaults for docker-compose.yml. These create/use a fresh Postgres container.
DOCKER_MULTIAGENT_PG_HOST=db
DOCKER_MULTIAGENT_PG_PORT=5432
DOCKER_MULTIAGENT_PG_DB=multiagente
DOCKER_MULTIAGENT_PG_USER=admin
DOCKER_MULTIAGENT_PG_PASSWORD=multi-claw-dev
MULTIAGENT_PG_SCHEMA=multiagente

# Optional host ports.
APP_PORT=8000
POSTGRES_PUBLIC_PORT=5433

# Optional local bind mount. Relative paths are resolved from this repository.
WORKING_PATH_HOST=./working-dir

# Optional integrations.
TWILIO_VALIDATE_SIGNATURE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_ALLOWED_FROM=
PUBLIC_BASE_URL=
