{
    "_runner": {
        "max_iterations": 400
    },
    "_defaults": {
        "model": "gpt-5.6",
        "reasoning": {
            "effort": "high",
            "summary": "auto"
        },
        "parallel_tool_calls": false,
        "max_iterations": 10
    },
    "ExecutorAgent": {
        "tools": ["WebSearchAgent", "DeviceManagerAgent", "PlaywrightSessionAgent", "save_preference", "read_file", "memory_query", "interpret_image"],
        "main": true,
        "json_response": false
    },
    "WebSearchAgent": {
        "tools": [{"type": "web_search"}],
        "json_response": false,
        "parallel_tool_calls": true,
        "model": "gpt-5.4"
    },
    "DeviceManagerAgent": {
        "tools": ["read_file", "file_hash", "run_python", "run_command", "write_file", "edit_file", "WebSearchAgent", "PlaywrightSessionAgent", "memory_query", "playwright_navigate", "web_fetch", "interpret_image"],
        "json_response": true,
        "parallel_tool_calls": true
    },
    "PlaywrightSessionAgent": {
        "tools": ["playwright_session", "web_fetch", "read_file", "file_hash", "interpret_image", "memory_query"],
        "json_response": true,
        "parallel_tool_calls": true
    }
}
